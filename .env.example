# OpenClaw Setup — copy this file to .env and fill in your keys
# cp .env.example .env
#
# Never share your .env file. It contains private credentials.

# ─────────────────────────────────────────────
# GROQ (required — free tier works fine)
# Get your key at: https://console.groq.com
# Sign in → API Keys → Create API Key
# ─────────────────────────────────────────────
GROQ_API_KEY="gsk_your_key_here"

# ─────────────────────────────────────────────
# TELEGRAM (optional — add if you want OpenClaw
# connected to a Telegram bot)
# Create a bot: https://t.me/BotFather → /newbot
# ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=""

# Your personal Telegram user ID (not your username).
# Find it: message your bot once → pairing screen shows "Your Telegram user id: XXXXXXX"
# Required for GitHub → Telegram notifications (gh-notify.sh / gh-reply.sh)
TELEGRAM_OWNER_CHAT_ID=""

# ─────────────────────────────────────────────
# DISCORD (optional — add if you want OpenClaw
# connected to a Discord server)
# Create a bot: https://discord.com/developers/applications
# ─────────────────────────────────────────────
# DISCORD_BOT_TOKEN=""
